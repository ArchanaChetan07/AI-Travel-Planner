# ── Demo / offline (works without Groq) ───────────────────────────────────────
DEMO_MODE=1

# ── Optional live LLM ─────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com — set DEMO_MODE=0 to use it
GROQ_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
DEFAULT_BUDGET_USD=150
LOG_LEVEL=INFO
